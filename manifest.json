{
  "manifest_version": 3,
  "name": "ChatHop - 聊天兔子",
  "version": "2.0.0",
  "description": "🐰 为 AI 对话网页提供侧边栏时间线导航，快速跳转到长对话中的任何消息。支持千问、元宝等主流 AI 平台。",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://www.qianwen.com/*",
    "https://qianwen.com/*",
    "https://tongyi.aliyun.com/*",
    "https://yuanbao.tencent.com/*",
    "https://chat.deepseek.com/*",
    "https://kimi.moonshot.cn/*",
    "https://chat.doubao.com/*",
    "https://yiyan.baidu.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.qianwen.com/*",
        "https://qianwen.com/*",
        "https://tongyi.aliyun.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://yuanbao.tencent.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chat.deepseek.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://kimi.moonshot.cn/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chat.doubao.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://yiyan.baidu.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
